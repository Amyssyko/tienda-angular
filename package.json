{
  "name": "tienda-app",
  "version": "0.0.4",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev": "ng serve",
    "lint": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.spec.json",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false --no-progress",
    "security:check-config": "bun scripts/security/check-bun-hardening.mjs",
    "security:check-exceptions-expiry": "bun scripts/security/check-exceptions-expiry.mjs",
    "security:audit": "bun audit",
    "security:enforce-audit": "bun scripts/security/enforce-audit-policy.mjs --policy-file security/audit-grace-policy.json --audit-file bun-audit.txt --npm-audit-file npm-audit.json",
    "security:enforce-osv": "bun scripts/security/enforce-osv-policy.mjs --exceptions-file security/osv-exceptions.json --results-file osv-results.json",
    "prepush:ci": "bun scripts/security/prepush-ci.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.11",
    "@angular/cdk": "21.2.9",
    "@angular/common": "21.2.11",
    "@angular/compiler": "21.2.11",
    "@angular/core": "21.2.11",
    "@angular/forms": "21.2.11",
    "@angular/material": "21.2.9",
    "@angular/platform-browser": "21.2.11",
    "@angular/platform-browser-dynamic": "21.2.11",
    "@angular/router": "21.2.11",
    "flowbite": "4.0.1",
    "ngx-toastr": "20.0.5",
    "rxjs": "7.8.2",
    "tailwindcss-animated": "2.0.0",
    "tslib": "2.8.1",
    "tw-elements": "2.0.0",
    "zone.js": "0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.2.9",
    "@angular/cli": "21.2.9",
    "@angular/compiler-cli": "21.2.11",
    "@tailwindcss/postcss": "4.2.4",
    "@types/cors": "2.8.19",
    "@types/jasmine": "6.0.0",
    "@vitest/browser-playwright": "4.1.5",
    "autoprefixer": "10.5.0",
    "jsdom": "29.1.1",
    "playwright": "1.59.1",
    "postcss": "8.5.12",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "packageManager": "bun@1.3.13"
}
